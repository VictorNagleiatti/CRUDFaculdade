@page
@model CrudFaculdade.Web.Pages.Produtos.IndexModel

<div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-1">Produtos</h2>
        <div class="text-muted small">Gerencie seus produtos (CRUD)</div>
    </div>

    <a class="btn btn-primary" asp-page="Create">
        <span class="me-1">+</span> Novo Produto
    </a>
</div>

<!-- Filtros -->
<form method="get" class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label mb-1">Buscar por nome</label>
                <input class="form-control" name="Q" value="@Model.Q" placeholder="Ex: Monitor, Mouse..." />
            </div>

            <div class="col-md-4">
                <label class="form-label mb-1">Categoria</label>
                <input class="form-control" name="Categoria" value="@Model.Categoria" placeholder="Ex: Periféricos, GPU..." />
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">Filtrar</button>
                <a class="btn btn-outline-secondary w-100" asp-page="Index">Limpar</a>
            </div>
        </div>
    </div>
</form>

<!-- Tabela -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3" style="width:70px;">Id</th>
                        <th>Nome</th>
                        <th style="width:150px;">Preço</th>
                        <th style="width:120px;">Estoque</th>
                        <th style="width:180px;">Categoria</th>
                        <th style="width:110px;">Ativo</th>
                        <th class="text-end pe-3" style="width:190px;">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Model.Produtos)
                    {
                        <tr>
                            <td class="ps-3 text-muted">@p.Id</td>

                            <td>
                                <div class="fw-semibold">@p.Nome</div>
                                <div class="small text-muted">
                                    Categoria: @(string.IsNullOrWhiteSpace(p.Categoria) ? "-" : p.Categoria)
                                </div>
                            </td>

                            <td class="fw-semibold">R$ @p.Preco.ToString("N2")</td>

                            <td>
                                <span class="badge bg-secondary text-white px-2 py-1">@p.Estoque</span>
                            </td>

                            <td>@(string.IsNullOrWhiteSpace(p.Categoria) ? "-" : p.Categoria)</td>

                            <td>
                                @if (p.Ativo)
                                {
                                    <span class="badge bg-success text-white px-2 py-1">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger text-white px-2 py-1">Inativo</span>
                                }
                            </td>

                            <td class="text-end pe-3">
                                <a class="btn btn-sm btn-outline-warning" asp-page="Edit" asp-route-id="@p.Id">Editar</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@p.Id">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>