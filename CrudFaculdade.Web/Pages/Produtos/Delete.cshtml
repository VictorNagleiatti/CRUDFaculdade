@page "{id:int}"
@model CrudFaculdade.Web.Pages.Produtos.DeleteModel

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-1">Excluir Produto</h2>
        <div class="text-muted small">Confirme a exclusão</div>
    </div>
    <a class="btn btn-outline-secondary" asp-page="Index">Voltar</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="alert alert-warning mb-3">
            Tem certeza que deseja excluir <strong>@Model.Produto.Nome</strong>?
        </div>

        <div class="row g-2 small">
            <div class="col-md-6"><span class="text-muted">Id:</span> <strong>@Model.Produto.Id</strong></div>
            <div class="col-md-6"><span class="text-muted">Preço:</span> <strong>R$ @Model.Produto.Preco.ToString("N2")</strong></div>
            <div class="col-md-6"><span class="text-muted">Estoque:</span> <strong>@Model.Produto.Estoque</strong></div>
            <div class="col-md-6"><span class="text-muted">Categoria:</span> <strong>@Model.Produto.Categoria</strong></div>
        </div>

        <form method="post" class="mt-4 d-flex gap-2">
            <button class="btn btn-danger" type="submit">Confirmar Exclusão</button>
            <a class="btn btn-secondary" asp-page="Index">Cancelar</a>
        </form>
    </div>
</div>